title: PyTorch Foundation Artwork
description: >-
  Logos and branding assets for the PyTorch Foundation, its foundation-hosted projects,
  ecosystem projects, and working groups.

favicon: assets/img/favicon.png
primary_logo: 
header_logo: assets/img/pytorch_foundation_logo/horizontal/svg/PyTorchFLogo_Horiz_White.svg
github_repo: https://github.com/pytorch-fdn/artwork
section_image: assets/img/pytorch_bg.jpg
theme_color_1: DE3412
theme_color_2: F05F42

logo_categories:
  - Foundation-hosted Projects
  - Ecosystem Projects
  - Working Groups
  - Other Logos
  
defaults:
  - scope:
      path: "other"
      type: "pages"
    values:
      layout: "logos"
      level: "Other Logos"

  - scope:
      path: "projects/foundation-hosted"
      type: "pages"
    values:
      layout: "logos"
      level: "Foundation-hosted Projects"

  - scope:
      path: "projects/ecosystem"
      type: "pages"
    values:
      layout: "logos"
      level: "Ecosystem Projects"

  - scope:
      path: "working-groups"
      type: "pages"
    values:
      layout: "logos"
      level: "Working Groups"

plugins:
  - jekyll-remote-theme
remote_theme: jmertic/artwork-template
